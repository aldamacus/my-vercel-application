{
  "name": "my-vercel-application",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:push": "npx drizzle-kit push --config drizzle.local.config.ts",
    "db:push:prod": "npx drizzle-kit push --config drizzle.prod.config.ts --force",
    "db:push:preview": "npx drizzle-kit push --config drizzle.preview.config.ts --force",
    "db:studio": "npx drizzle-kit studio --config drizzle.local.config.ts",
    "seed:admin": "dotenv -e .env.local -- npx tsx scripts/seed-admin.ts",
    "seed:admin:preview": "dotenv -e .env.preview.local -- npx tsx scripts/seed-admin.ts",
    "seed:admin:prod": "dotenv -e .env.production.local -- npx tsx scripts/seed-admin.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@tailwindcss/postcss": "^4.1.8",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "jose": "^6.2.2",
    "lucide-react": "^0.511.0",
    "next": "^16.2.3",
    "node-ical": "^0.20.1",
    "postcss": "^8.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "22.15.29",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.3.2",
    "react-day-picker": "^9.11.3",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.3",
    "typescript": "5.8.3"
  }
